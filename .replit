entrypoint = "mcp_host/server.py"
modules = ["python-3.11"]

[nix]
channel = "stable-24_05"

[env]
PORT = "8080"
PYTHONPATH = "/home/runner/workspace"

[deployment]
build = ["sh", "install.sh"]
run = ["sh", "-c", "unset DATABASE_URL; MCP_HOST_DB=/home/runner/workspace/mcp-host.db MCP_HOST_TENANT_DB=/home/runner/workspace/mcp-host-tenant.db MCP_HOST_ARTIFACTS=/home/runner/workspace/objects PYTHONPATH=.pythonlibs:/home/runner/workspace python3 -m uvicorn mcp_host.server:app --host 0.0.0.0 --port 8080 --timeout-keep-alive 120 --timeout-graceful-shutdown 30"]
deploymentTarget = "vm"

[[ports]]
localPort = 8080
externalPort = 8080

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn mcp_host.server:app --host 0.0.0.0 --port 8080 --timeout-keep-alive 120"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "console"
