# MCP-Host environment — copy real values into Replit Deployment Secrets (NOT into git).
# DATABASE_URL is auto-provided by Replit Postgres; do not set it yourself.

# ── Required platform config ────────────────────────────────────────────────
# Your real public URL after the Repl exists (no trailing slash). Until set, /health = degraded.
MCP_HOST_BASE_URL=https://YOUR-REPL.replit.app
# Strong random secrets — generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
MCP_HOST_SIGNING_KEY=CHANGE_ME_long_random_secret
UPLOAD_SECRET=CHANGE_ME_long_random_secret
# Shared receiving wallet (common to all your MCPs; from edgar-rag). Public address, Base L2 / USDC.
WALLET_ADDRESS=0x038326AF0793eC0dE8b1f18d0f4f0184FA965e8C
# Persistent artifact dir on the Reserved VM (NOT /tmp).
MCP_HOST_ARTIFACTS=/home/runner/workspace/objects

# ── Per-provider third-party secrets (add the ones your mounted providers need) ──
# edgar-rag:
SEC_USER_AGENT=BGLabs bilko@bilko.run
# social-trader (copy real values from ~/Projects/social-signals-trader/.env):
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ANTHROPIC_API_KEY=

# ── Reserved for later (real x402 client; currently a stub, not consumed yet) ──
# X402_FACILITATOR_URL=https://x402.org/facilitator
